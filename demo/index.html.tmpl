<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>mnemo - live Nebula demo</title>
<meta name="description" content="The real mnemo Nebula: 3-panel shell, file tree, filter, node detail + connections, hover/select/highlight -- on a seeded synthetic graph of mnemo's own architecture. Static, no backend.">
<link rel="icon" type="image/svg+xml" href="mark.svg">
<link rel="stylesheet" href="app.css">
<style>
  /* the demo supplies only its own topbar; everything below is the
     REAL app.css (the .nebula-shell / panels / detail / tree). */
  body{margin:0;background:#07090f;color:#e6edf3;
    font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,sans-serif}
  .demo-top{
    height:var(--topbar-h,56px);box-sizing:border-box;display:flex;
    align-items:center;gap:12px;padding:0 18px;
    border-bottom:1px solid rgba(126,231,224,.12);
    background:rgba(8,11,19,.92)
  }
  .demo-top img{width:22px;height:22px}
  .demo-top b{font-size:16px;letter-spacing:.4px}
  .demo-top .v{font:600 11px/1 ui-monospace,monospace;color:#07090f;
    background:#7ee7e0;padding:4px 8px;border-radius:999px}
  .demo-top .sp{margin-left:auto;color:#8b95a7;font-size:12.5px}
  .demo-top a{color:#7ee7e0;text-decoration:none}
  .demo-empty{color:#8b95a7;font-size:13px;line-height:1.6}
  .demo-chips{display:flex;flex-wrap:wrap;gap:6px;margin:.5rem 0 .75rem}
  .demo-chip{font:600 11px/1 ui-sans-serif,system-ui,sans-serif;
    color:#cdd6e3;background:rgba(126,231,224,.08);
    border:1px solid rgba(126,231,224,.18);border-radius:999px;
    padding:6px 10px;cursor:pointer}
  .demo-chip.off{opacity:.4}
  .demo-find{width:100%;box-sizing:border-box;margin:.25rem 0 .5rem;
    background:#05070c;color:#e6edf3;border:1px solid rgba(126,231,224,.18);
    border-radius:8px;padding:8px 10px;font:13px ui-sans-serif,system-ui}
  /* the filter section is a full-width bar on the SHELL's 2nd grid
     row (grid-template-rows:1fr auto) -- the bottom of the window,
     NOT inside the file panel. */
  .demo-filterbar{grid-column:1 / -1;grid-row:2 / 3;display:flex;
    align-items:center;gap:10px;flex-wrap:wrap;padding:8px 14px;
    background:rgba(8,11,19,.92);
    border-top:1px solid rgba(126,231,224,.12)}
  .demo-filterbar .fb-label{color:#8b95a7;font:600 11px/1 ui-monospace,
    monospace;text-transform:uppercase;letter-spacing:.08em}
  .demo-filterbar .demo-find{flex:0 0 240px;margin:0}
  .demo-filterbar .demo-chips{flex:1 1 auto;margin:0}
  .nb-body{background:#05070c;border:1px solid rgba(126,231,224,.14);
    border-radius:9px;padding:11px;margin:.5rem 0;overflow:auto;
    font:12px/1.55 ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
    color:#cdd6e3;white-space:pre-wrap;word-break:break-word}
  .nb-conn{list-style:none;margin:.4rem 0 0;padding:0}
  .nb-conn li{display:flex;justify-content:space-between;gap:8px;
    padding:7px 9px;border:1px solid rgba(126,231,224,.10);
    border-radius:8px;margin-bottom:6px;cursor:pointer;font-size:12.5px}
  .nb-conn li:hover{background:rgba(126,231,224,.07)}
  .nb-conn .r{color:#8b95a7;font:11px ui-monospace,monospace}
  .tree-group{cursor:pointer;color:#cdd6e3;font-weight:650;
    padding:6px 4px;display:flex;gap:6px;align-items:center}
  .tree-group .n{margin-left:auto;color:#8b95a7;font:11px ui-monospace,monospace}
  .tree-file{display:block;color:#aeb8c7;text-decoration:none;
    padding:4px 6px 4px 20px;border-radius:6px;font-size:12.5px;
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .tree-file:hover{background:rgba(126,231,224,.07);color:#e6edf3}
  .tree-file.active{background:rgba(126,231,224,.14);color:#7ee7e0}
  .demo-close{float:right;background:none;border:0;color:#8b95a7;
    font-size:20px;cursor:pointer;line-height:1}
  .demo-close:hover{color:#e6edf3}
  .ntype{display:inline-block;font:600 10.5px/1 ui-monospace,monospace;
    color:var(--type-color,#7ee7e0);border:1px solid var(--type-color,#7ee7e0);
    border-radius:999px;padding:5px 9px;margin-bottom:8px}
  .nsource{color:#8b95a7;font:11.5px ui-monospace,monospace;
    word-break:break-all;margin:.25rem 0}
  .ndesc{color:#c7d0de;font-size:13px;line-height:1.55;margin:.4rem 0}
  .demo-status{position:absolute;left:14px;bottom:12px;z-index:6;
    color:#8b95a7;font:12px ui-sans-serif,system-ui;pointer-events:none}
  .demo-hud{position:absolute;left:14px;top:12px;z-index:6;display:flex;gap:8px}
  .demo-hud button{font:600 12px ui-sans-serif,system-ui;color:#e6edf3;
    background:rgba(13,16,24,.85);border:1px solid rgba(126,231,224,.18);
    border-radius:999px;padding:7px 12px;cursor:pointer}
  .demo-hud button.off{color:#8b95a7;opacity:.6}
  .nebula-booting{position:absolute;inset:0;display:flex;align-items:center;
    justify-content:center;color:#8b95a7;font:600 13px ui-monospace,monospace;z-index:7}
</style>
</head>
<body>
<header class="demo-top">
  <img src="mark.svg" alt="mnemo">
  <b>mnemo</b><span class="v">v%%VERSION%%</span>
  <span class="sp">live Nebula on a seeded synthetic graph of mnemo's own architecture &middot;
    <a href="%%REPO_URL%%">source</a> &middot;
    run it locally: <code>./install.sh &amp;&amp; mnemo ui</code></span>
</header>

<section class="nebula-shell">
  <aside class="nebula-tree">
    <h3 class="tree-title">mnemo &mdash; synthetic graph</h3>
    <div id="tree"></div>
  </aside>

  <div class="nebula-canvas">
    <canvas id="nebula-gl"></canvas>
    <canvas id="nebula-labels"></canvas>
    <div id="cy-nebula"></div>
    <div class="demo-hud">
      <button id="t-edges">edges</button>
      <button id="t-labels">labels</button>
    </div>
    <div class="demo-status" id="status">loading&hellip;</div>
    <div class="nebula-booting" id="boot">warming the nebula&hellip;</div>
  </div>

  <aside class="nebula-detail" id="detail">
    <div class="demo-empty" id="empty">
      Click a star on the canvas (or a file in the tree) to see its
      type, source, description, body, and its connections &mdash;
      exactly like the local <code>/graph</code>. Drag to pan, scroll
      to zoom, click empty space or press <kbd>Esc</kbd> to deselect.
    </div>
    <div id="card" style="display:none">
      <button class="demo-close" id="close" title="Deselect (Esc)">&times;</button>
      <span class="ntype" id="d-type"></span>
      <h3 id="d-name" style="margin:.2rem 0;font-size:16px"></h3>
      <p class="nsource" id="d-src"></p>
      <p class="ndesc" id="d-desc"></p>
      <div class="nb-body" id="d-body"></div>
      <h4 id="d-conn-h" style="font-size:13px;color:#8b95a7;margin:.9rem 0 .2rem"></h4>
      <ul class="nb-conn" id="d-conn"></ul>
    </div>
  </aside>

  <div class="demo-filterbar">
    <span class="fb-label">filter</span>
    <input class="demo-find" id="find" placeholder="name / type&hellip;" autocomplete="off">
    <div class="demo-chips" id="chips"></div>
  </div>
</section>

<script src="regl.min.js"></script>
<script src="nebula-gl.js"></script>
<script>
(function () {
  "use strict";
  var boot = document.getElementById("boot");
  function fail(m) { if (boot) boot.textContent = m; }
  if (!window.createREGL || !window.NebulaGL) return fail("renderer failed to load");

  function esc(s) {
    return String(s).replace(/[&<>]/g, function (c) {
      return { "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c];
    });
  }
  function hex(c) {
    function h(v) { return ("0" + Math.round(v * 255).toString(16)).slice(-2); }
    return "#" + h(c[0]) + h(c[1]) + h(c[2]);
  }

  fetch("nebula.json").then(function (r) {
    if (!r.ok) throw new Error("nebula.json " + r.status);
    return r.json();
  }).then(function (data) {
    var nodes = data.nodes, edges = data.edges, adj = data.adj || {};
    var cv = document.getElementById("nebula-gl");
    var labels = window.NebulaGL.LabelProvider(
      document.getElementById("nebula-labels"));
    var gl = window.NebulaGL.create(cv, {
      nodes: nodes, edges: edges, labels: labels,
      theme: {
        bg: [0.027, 0.035, 0.059, 1.0],
        edge: [0.42, 0.54, 0.86, 0.085],
        glow: 0.9, accent: [0.494, 0.906, 0.878]
      }
    });
    labels.setLabels(nodes.map(function (n) {
      return { x: n.x, y: n.y, text: n.name };
    }));
    if (boot) boot.style.display = "none";
    document.getElementById("status").textContent =
      nodes.length + " nodes · " + edges.length +
      " edges · seeded synthetic mnemo galaxy (static demo)";

    // --- detail panel (mirrors the local /graph) ---
    var card = document.getElementById("card");
    var empty = document.getElementById("empty");
    var selId = -1;
    function deselect() {
      selId = -1; card.style.display = "none"; empty.style.display = "";
      gl.select(null);
      var a = document.querySelector(".tree-file.active");
      if (a) a.classList.remove("active");
    }
    function select(i) {
      var n = nodes[i]; if (!n) return;
      selId = i;
      empty.style.display = "none"; card.style.display = "";
      var ty = document.getElementById("d-type");
      ty.textContent = n.type;
      ty.style.setProperty("--type-color", hex(n.color));
      ty.className = "ntype ntype-" + n.type;
      document.getElementById("d-name").textContent = n.name;
      var se = document.getElementById("d-src");
      se.textContent = n.src || ""; se.style.display = n.src ? "" : "none";
      document.getElementById("d-desc").textContent = n.desc || "";
      document.getElementById("d-body").textContent = n.body || "";
      var nb = adj[String(i)] || [];
      document.getElementById("d-conn-h").textContent =
        "Connections (" + nb.length + ")";
      var ul = document.getElementById("d-conn");
      ul.innerHTML = "";
      nb.slice(0, 60).forEach(function (e) {
        var m = nodes[e.i]; if (!m) return;
        var li = document.createElement("li");
        li.innerHTML = "<span>" + esc(m.short || m.name) +
          "</span><span class='r'>" + esc(e.rel) + " · " +
          e.conf.toFixed(2) + "</span>";
        li.onclick = function () { select(e.i); };
        ul.appendChild(li);
      });
      var a = document.querySelector(".tree-file.active");
      if (a) a.classList.remove("active");
      var tf = document.querySelector('.tree-file[data-i="' + i + '"]');
      if (tf) { tf.classList.add("active"); }
      gl.select(i);  // renderer camera-fly + focus -- the SINGLE
                     // source, so a CANVAS click focuses too (not
                     // only tree/neighbour clicks).
    }
    gl.on("clickNode", function (i) { select(i); });
    gl.on("clickStage", function () { deselect(); });
    document.getElementById("close").onclick = deselect;
    window.addEventListener("keydown", function (e) {
      if (e.key === "Escape") deselect();
    });

    // --- toggles --- (labels default OFF: auto-off the display)
    var eOn = true, lOn = false;
    var be = document.getElementById("t-edges");
    var bl = document.getElementById("t-labels");
    gl.setEdgesVisible(eOn); gl.setLabelsVisible(lOn);
    bl.classList.toggle("off", !lOn);  // reflect the default-off state
    be.onclick = function () {
      eOn = !eOn; gl.setEdgesVisible(eOn); be.classList.toggle("off", !eOn);
    };
    bl.onclick = function () {
      lOn = !lOn; gl.setLabelsVisible(lOn); bl.classList.toggle("off", !lOn);
    };

    // --- type-chip + text filter (dim non-matching, never hide) ---
    var types = {};
    nodes.forEach(function (n) { types[n.type] = (types[n.type] || 0) + 1; });
    var off = {};
    var chipBox = document.getElementById("chips");
    Object.keys(types).sort().forEach(function (t) {
      var b = document.createElement("button");
      b.className = "demo-chip"; b.textContent = t + " (" + types[t] + ")";
      b.onclick = function () {
        off[t] = !off[t]; b.classList.toggle("off", !!off[t]); applyFilter();
      };
      chipBox.appendChild(b);
    });
    var find = document.getElementById("find");
    find.addEventListener("input", applyFilter);
    function applyFilter() {
      var q = find.value.trim().toLowerCase();
      var anyOff = Object.keys(off).some(function (k) { return off[k]; });
      if (!q && !anyOff) { gl.setHighlight(null); return; }
      var keep = new Set();
      nodes.forEach(function (n, i) {
        if (off[n.type]) return;
        if (q && n.name.toLowerCase().indexOf(q) < 0 &&
                 n.type.toLowerCase().indexOf(q) < 0) return;
        keep.add(i);
      });
      gl.setHighlight(keep);
    }

    // --- left tree: group by source directory (like the file tree) ---
    var groups = {};
    nodes.forEach(function (n, i) {
      var g = n.src ? n.src.split("/").slice(0, 3).join("/") : ("type:" + n.type);
      (groups[g] || (groups[g] = [])).push(i);
    });
    var tree = document.getElementById("tree");
    Object.keys(groups).sort().forEach(function (g) {
      var head = document.createElement("div");
      head.className = "tree-group";
      head.innerHTML = "<span>▾</span><span>" + esc(g) +
        "</span><span class='n'>" + groups[g].length + "</span>";
      var box = document.createElement("div");
      groups[g].slice(0, 40).forEach(function (i) {
        var a = document.createElement("a");
        a.className = "tree-file vscode-file";
        a.href = "#"; a.setAttribute("data-i", i);
        a.textContent = nodes[i].short || nodes[i].name;
        a.onclick = function (ev) {
          ev.preventDefault(); select(i);
        };
        box.appendChild(a);
      });
      var openTog = true;
      head.onclick = function () {
        openTog = !openTog; box.style.display = openTog ? "" : "none";
        head.firstChild.textContent = openTog ? "▾" : "▸";
      };
      tree.appendChild(head); tree.appendChild(box);
    });
  }).catch(function (e) { fail("could not load the graph: " + e.message); });
})();
</script>
</body>
</html>
